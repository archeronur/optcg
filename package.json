{
  "name": "optcg-tools",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cf": "OPENNEXT_CLOUDFLARE_DEV=1 next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "opennextjs-cloudflare build && node scripts/cf-pages-prep.mjs",
    "build:next": "next build",
    "clean": "rm -rf .next .open-next",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && node scripts/cf-pages-prep.mjs && opennextjs-cloudflare preview --config wrangler.worker.jsonc",
    "deploy": "opennextjs-cloudflare build && node scripts/cf-pages-prep.mjs && opennextjs-cloudflare deploy --config wrangler.worker.jsonc",
    "lint": "next lint",
    "cf-typegen": "wrangler types --config wrangler.worker.jsonc --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4.2.2",
    "fuse.js": "^7.0.0",
    "next": "^15.5.14",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "typescript": "^5.0.0",
    "wrangler": "^4.76.0"
  }
}
